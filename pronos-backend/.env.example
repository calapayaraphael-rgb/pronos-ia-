# ---- Serveur ----
PORT=8080
NODE_ENV=development
# Origines autorisees pour le frontend (separees par des virgules)
CORS_ORIGINS=http://localhost:5173,https://votre-frontend

# ---- Base de donnees ----
DATABASE_URL=postgres://pronos:pronos@localhost:5432/pronos

# ---- Securite ----
# Genere une longue chaine aleatoire : openssl rand -hex 48
JWT_SECRET=change-moi-vraiment

# Seed d'un premier compte au demarrage (optionnel, single-user v1)
BOOTSTRAP_ADMIN_EMAIL=moi@exemple.fr
BOOTSTRAP_ADMIN_PASSWORD=changeme

# ---- Donnees sportives ----
# Cles : the-odds-api.com (matchs + cotes reelles)
ODDS_API_KEY=
ODDS_REGIONS=eu
# Sports a suivre = sport_key The Odds API, separes par des virgules
# ex: soccer_france_ligue_one,soccer_uefa_champs_league,basketball_nba,icehockey_nhl
TRACKED_SPORTS=soccer_france_ligue_one,basketball_nba

# ---- IA ----
# console.anthropic.com. Si vide, le backend calcule la valeur de cote sans avis IA.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Blessures / compositions (optionnel, exemple football) ----
# api-football.com. Sans cle, l'adaptateur renvoie honnetement "non disponible".
API_FOOTBALL_KEY=

# ---- Filtres qualite (refus automatique) ----
MIN_RELIABILITY=60
MIN_EV=0.02
MAX_RISK=moyen
START_BANKROLL=100

# ---- Planificateur (cron) ----
JOBS_ENABLED=true
POLL_ODDS_CRON=*/5 * * * *
CLOSING_CRON=* * * * *
POLL_RESULTS_CRON=*/15 * * * *
POLL_INJURIES_CRON=*/30 * * * *

# ---- Paiement (optionnel, scaffolding) ----
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
