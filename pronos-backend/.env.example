# ---- Serveur ----
PORT=8080
NODE_ENV=development
# Origines autorisees pour le frontend (separees par des virgules)
CORS_ORIGINS=http://localhost:5173,https://pronos-ia.vercel.app

# ---- Base de donnees ----
DATABASE_URL=postgres://pronos:pronos@localhost:5432/pronos

# ---- Securite ----
# Genere une longue chaine aleatoire : openssl rand -hex 48
JWT_SECRET=change-moi-vraiment

# Seed d'un premier compte admin au demarrage (optionnel)
BOOTSTRAP_ADMIN_EMAIL=moi@exemple.fr
BOOTSTRAP_ADMIN_PASSWORD=changeme

# ---- The Odds API (matchs + cotes reelles) ----
# Cle : the-odds-api.com. Sans vraie cle le serveur demarre quand meme et
# GET /api/v1/health/data explique pourquoi le site est vide.
ODDS_API_KEY=
ODDS_REGIONS=eu,uk
ODDS_MARKETS=h2h,spreads,totals
ODDS_FORMAT=decimal
ODDS_DATE_FORMAT=iso
# Sports a suivre = sport_key The Odds API, separes par des virgules.
# Vide = liste par defaut (Ligue 1, EPL, Liga, Serie A, Bundesliga, LdC, NBA, tennis).
TRACKED_SPORTS=

# ---- IA (console.anthropic.com) ----
# Si vide, le backend calcule la valeur de cote sans avis IA (engine_only).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# ---- Blessures / compositions (optionnel, exemple football) ----
# api-football.com. Sans cle, l'adaptateur renvoie honnetement "non disponible".
API_FOOTBALL_KEY=

# ---- Filtres qualite (refus automatique) ----
MIN_RELIABILITY=60
MIN_EV=0.02
MIN_EDGE_PERCENT=3
MIN_CONFIDENCE=60
MAX_PRONOS_PER_SYNC=30
MAX_RISK=moyen
START_BANKROLL=100

# ---- Planificateur ----
JOBS_ENABLED=true
# Cadence de la sync des cotes (minutes). Render free : le service peut
# dormir ; utilisez aussi le bouton "Sync complete" de la page admin.
SYNC_INTERVAL_MINUTES=15
PREDICTIONS_CRON=*/30 * * * *
CLOSING_CRON=* * * * *
POLL_RESULTS_CRON=0 * * * *
POLL_INJURIES_CRON=*/30 * * * *

# ---- Paiement (optionnel, scaffolding) ----
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
